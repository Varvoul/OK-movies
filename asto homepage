// ============================================================
// Muvix‑VQ – Homepage (index.astro)
// Edge-to-edge layout: Main content + Right Sidebar flush
// Hero slider full width | Matches HiAnime wide layout
// ============================================================

const TMDB_PROXY = import.meta.env.PUBLIC_TMDB_PROXY || '';
const JIKAN_BASE = 'https://api.jikan.moe/v4';

async function fetchTMDB(endpoint, params = '') {
  const url = `${TMDB_PROXY}/3${endpoint}?${params}`;
  const res = await fetch(url);
  if (!res.ok) return { results: [] };
  return res.json();
}
async function fetchJikan(endpoint, params = '') {
  const url = `${JIKAN_BASE}/${endpoint}?${params}`;
  const res = await fetch(url);
  if (!res.ok) return { data: [] };
  return res.json();
}
function tmdbImage(path, size = 'w500') {
  return path ? `https://image.tmdb.org/t/p/${size}${path}` : '';
}

// 1. HERO SLIDER
async function fetchHeroData() {
  const [trendMovies, trendTV] = await Promise.all([
    fetchTMDB('/trending/movie/week', 'language=en-US'),
    fetchTMDB('/trending/tv/week', 'language=en-US')
  ]);
  const tmdbHeroes = [...(trendMovies.results || []), ...(trendTV.results || [])]
    .slice(0, 10).map(item => ({
      id: `tmdb-${item.id}`,
      title: item.title || item.name,
      type: item.media_type === 'movie' ? 'Movie' : 'TV',
      genres: item.genre_ids?.slice(0,5).map(g => g.toString()) || [],
      score: item.vote_average?.toFixed(1) || '?',
      year: (item.release_date || item.first_air_date || '').slice(0,4),
      quality: 'HD',
      duration: item.media_type === 'movie' ? '1h 45m' : '24m/ep',
      overview: item.overview || '',
      backdrop: tmdbImage(item.backdrop_path, 'w1280'),
      poster: tmdbImage(item.poster_path),
      mediaType: item.media_type === 'movie' ? 'movie' : 'tv',
      releaseDate: item.release_date || item.first_air_date || '',
    }));
  const jikanTop = await fetchJikan('top/anime', 'limit=9');
  const jikanHeroes = (jikanTop.data || []).map(anime => ({
    id: `jikan-${anime.mal_id}`,
    title: anime.title,
    type: 'Anime',
    genres: anime.genres?.map(g => g.name).slice(0,5) || [],
    score: anime.score?.toFixed(1) || '?',
    year: anime.aired?.from?.slice(0,4) || '?',
    quality: 'HD',
    duration: anime.episodes ? `${anime.episodes} eps` : 'Ongoing',
    overview: anime.synopsis || '',
    backdrop: anime.trailer?.images?.large_image_url || anime.images?.jpg?.large_image_url || '',
    poster: anime.images?.jpg?.large_image_url || '',
    mediaType: 'anime',
    releaseDate: anime.aired?.from?.slice(0,10) || '',
  }));
  return [...tmdbHeroes, ...jikanHeroes].slice(0, 19);
}

// 2. TOP AIRING
async function fetchTopAiring() {
  const [tvOnAir, moviesUpcoming, jikanAiring] = await Promise.all([
    fetchTMDB('/tv/on_the_air', 'language=en-US&page=1'),
    fetchTMDB('/movie/upcoming', 'language=en-US&page=1'),
    fetchJikan('top/anime', 'filter=airing&limit=15')
  ]);
  const tmdbTV = (tvOnAir.results || []).slice(0, 30).map(item => ({
    id: `tmdb-tv-${item.id}`, title: item.name,
    poster: tmdbImage(item.poster_path), type: 'TV',
    year: item.first_air_date?.slice(0,4) || '?', duration: '24m/ep',
    score: item.vote_average?.toFixed(1) || '?', mediaType: 'tv',
  }));
  const tmdbMovies = (moviesUpcoming.results || []).slice(0, 15).map(item => ({
    id: `tmdb-movie-${item.id}`, title: item.title,
    poster: tmdbImage(item.poster_path), type: 'Movie',
    year: item.release_date?.slice(0,4) || '?', duration: '1h 45m',
    score: item.vote_average?.toFixed(1) || '?', mediaType: 'movie',
  }));
  const jikanTV = (jikanAiring.data || []).map(anime => ({
    id: `jikan-air-${anime.mal_id}`, title: anime.title,
    poster: anime.images?.jpg?.large_image_url || '', type: 'Anime',
    year: anime.aired?.from?.slice(0,4) || '?',
    duration: anime.episodes ? `${anime.episodes} eps` : 'Ongoing',
    score: anime.score?.toFixed(1) || '?', mediaType: 'anime',
  }));
  return [...tmdbTV, ...tmdbMovies, ...jikanTV].slice(0, 60);
}

// 3. NEW RELEASES
async function fetchNewReleases() {
  const [tmdbMoviesNow, tmdbTVNow, jikanLatest] = await Promise.all([
    fetchTMDB('/movie/now_playing', 'language=en-US&page=1'),
    fetchTMDB('/tv/on_the_air', 'language=en-US&page=1'),
    fetchJikan('seasons/now', 'limit=20')
  ]);
  const makeMovie = item => ({
    id: `tmdb-movie-${item.id}`, title: item.title,
    poster: tmdbImage(item.poster_path), type: 'Movie', lang: 'Sub',
    duration: '1h 45m', contentRating: 'PG-13', quality: 'HD',
    score: item.vote_average?.toFixed(1) || '?', episodeInfo: '1h 45m', mediaType: 'movie',
  });
  const makeTV = item => ({
    id: `tmdb-tv-${item.id}`, title: item.name,
    poster: tmdbImage(item.poster_path), type: 'TV', lang: 'Sub',
    duration: '24m/ep', contentRating: 'PG-13', quality: 'HD',
    score: item.vote_average?.toFixed(1) || '?', episodeInfo: 'S03 E10', mediaType: 'tv',
  });
  const makeAnime = anime => ({
    id: `jikan-${anime.mal_id}`, title: anime.title,
    poster: anime.images?.jpg?.large_image_url || '', type: 'Anime', lang: 'Sub',
    duration: '24m/ep', contentRating: 'PG-13', quality: 'HD',
    score: anime.score?.toFixed(1) || '?',
    episodeInfo: anime.episodes ? `Ep ${anime.episodes}` : 'Ongoing', mediaType: 'anime',
  });
  const movies = (tmdbMoviesNow.results || []).slice(0, 10).map(makeMovie);
  const tv = (tmdbTVNow.results || []).slice(0, 10).map(makeTV);
  const anime = (jikanLatest.data || []).slice(0, 10).map(makeAnime);
  const all = [...movies, ...tv, ...anime].slice(0, 30);
  return { all, anime: anime.slice(0,30), movie: movies.slice(0,30), tv: tv.slice(0,30) };
}

// 4. UPCOMING
async function fetchUpcoming() {
  const [tmdbUpcoming, jikanUpcoming] = await Promise.all([
    fetchTMDB('/movie/upcoming', 'language=en-US&page=1'),
    fetchJikan('top/anime', 'filter=upcoming&limit=20')
  ]);
  const tmdb = (tmdbUpcoming.results || []).slice(0, 20).map(item => ({
    id: `tmdb-up-${item.id}`, title: item.title,
    poster: tmdbImage(item.poster_path), type: 'Movie',
    releaseDate: item.release_date || '',
    genres: item.genre_ids?.slice(0,6) || [], studio: '?',
    synopsis: item.overview || '', score: item.vote_average?.toFixed(1) || '?',
    contentRating: 'PG-13', duration: '2h 10m',
  }));
  const jikan = (jikanUpcoming.data || []).slice(0, 20).map(anime => ({
    id: `jikan-up-${anime.mal_id}`, title: anime.title,
    poster: anime.images?.jpg?.large_image_url || '', type: 'Anime',
    releaseDate: anime.aired?.from?.slice(0,10) || '',
    genres: anime.genres?.map(g => g.name).slice(0,6) || [],
    studio: anime.studios?.[0]?.name || '?', synopsis: anime.synopsis || '',
    score: anime.score?.toFixed(1) || '?', contentRating: 'PG-13',
    duration: anime.episodes ? `${anime.episodes} eps` : '?',
  }));
  return [...tmdb, ...jikan].slice(0, 40);
}

// 5. RECENT COMPLETED
async function fetchCompletedPage(page = 1) {
  const [moviesPage, animePage] = await Promise.all([
    fetchTMDB('/discover/movie', `sort_by=popularity.desc&primary_release_date.lte=2024&page=${page}`),
    fetchJikan('top/anime', `filter=completed&page=${page}`)
  ]);
  const movies = (moviesPage.results || []).map(item => ({
    id: `tmdb-comp-${item.id}`, title: item.title,
    poster: tmdbImage(item.poster_path), type: 'Movie',
    year: item.release_date?.slice(0,4) || '?',
    score: item.vote_average?.toFixed(1) || '?', quality: 'HD',
  }));
  const anime = (animePage.data || []).map(anime => ({
    id: `jikan-comp-${anime.mal_id}`, title: anime.title,
    poster: anime.images?.jpg?.large_image_url || '', type: 'Anime',
    year: anime.aired?.from?.slice(0,4) || '?',
    score: anime.score?.toFixed(1) || '?', quality: 'HD',
  }));
  return [...movies, ...anime].slice(0, 30);
}

// 6. TRENDING SIDEBAR
async function fetchTrending() {
  const [tmdbWeek, jikanAiring] = await Promise.all([
    fetchTMDB('/trending/all/week', 'language=en-US'),
    fetchJikan('top/anime', 'filter=airing&limit=10')
  ]);
  const tmdb = (tmdbWeek.results || []).slice(0, 10).map(item => ({
    id: `tmdb-tr-${item.id}`, title: item.title || item.name,
    poster: tmdbImage(item.poster_path),
    type: item.media_type === 'movie' ? 'Movie' : 'TV',
    year: (item.release_date || item.first_air_date || '').slice(0,4),
    score: item.vote_average?.toFixed(1) || '?', studio: '?',
    views: `${Math.floor(Math.random()*5000)} watching`, rank: 0, mediaType: item.media_type,
  }));
  const jikan = (jikanAiring.data || []).map(anime => ({
    id: `jikan-tr-${anime.mal_id}`, title: anime.title,
    poster: anime.images?.jpg?.large_image_url || '', type: 'Anime',
    year: anime.aired?.from?.slice(0,4) || '?',
    score: anime.score?.toFixed(1) || '?',
    studio: anime.studios?.[0]?.name || '?',
    views: `${Math.floor(Math.random()*3000)} watching`, rank: 0,
  }));
  const combined = [...tmdb, ...jikan].slice(0, 20);
  combined.sort((a, b) => (b.score || 0) - (a.score || 0));
  combined.forEach((item, idx) => item.rank = idx + 1);
  return combined.slice(0, 20);
}

// 7. MOST POPULAR SIDEBAR
async function fetchMostPopular() {
  const [tmdbPop, jikanPop] = await Promise.all([
    fetchTMDB('/movie/popular', 'language=en-US&page=1'),
    fetchJikan('top/anime', 'filter=bypopularity&limit=7')
  ]);
  const movies = (tmdbPop.results || []).slice(0, 7).map(item => ({
    id: `tmdb-pop-${item.id}`, title: item.title,
    poster: tmdbImage(item.poster_path), type: 'Movie',
    year: item.release_date?.slice(0,4) || '?',
    score: item.vote_average?.toFixed(1) || '?', studio: '?',
    views: `${Math.floor(Math.random()*8000)} watching`, rank: 0,
  }));
  const anime = (jikanPop.data || []).map(anime => ({
    id: `jikan-pop-${anime.mal_id}`, title: anime.title,
    poster: anime.images?.jpg?.large_image_url || '', type: 'Anime',
    year: anime.aired?.from?.slice(0,4) || '?',
    score: anime.score?.toFixed(1) || '?',
    studio: anime.studios?.[0]?.name || '?',
    views: `${Math.floor(Math.random()*6000)} watching`, rank: 0,
  }));
  const combined = [...movies, ...anime].slice(0, 13);
  combined.sort((a, b) => (b.score || 0) - (a.score || 0));
  combined.forEach((item, idx) => item.rank = idx + 1);
  return combined;
}

// 8. EPISODE SCHEDULE
async function fetchScheduleData() {
  const today = new Date();
  const dates = [];
  for (let i = 0; i < 7; i++) {
    const d = new Date(today);
    d.setDate(today.getDate() + i);
    dates.push(d.toISOString().slice(0, 10));
  }
  const [tmdbAiringToday, tmdbOnAir] = await Promise.all([
    fetchTMDB('/tv/airing_today', 'language=en-US'),
    fetchTMDB('/tv/on_the_air', 'language=en-US&page=1')
  ]);
  const dayNames = ['sunday','monday','tuesday','wednesday','thursday','friday','saturday'];
  const todayDayName = dayNames[today.getDay()];
  const jikanSchedule = await fetchJikan('schedules', `filter=${todayDayName}&kids=false&limit=50`);
  const scheduleMap = {};
  function addToSchedule(showId, title, url, airDate, airTime, episodeNumber, country) {
    const key = `${showId}-${airDate}`;
    if (!scheduleMap[key]) {
      scheduleMap[key] = { id: showId, title, url, airDate, airTime, episodeNumber, country: country || 'Japan' };
    }
  }
  const allTMDBTV = [...(tmdbAiringToday.results || []), ...(tmdbOnAir.results || [])];
  for (const show of allTMDBTV) {
    const airDate = show.first_air_date || today.toISOString().slice(0, 10);
    addToSchedule(`tmdb-tv-${show.id}`, show.name, `/details/tmdb-tv-${show.id}`, airDate, '21:00', show.number_of_episodes ? show.number_of_episodes : 1, show.origin_country?.[0] || 'US');
  }
  for (const anime of jikanSchedule.data || []) {
    const broadcastDay = anime.broadcast?.day || todayDayName;
    const broadcastTime = anime.broadcast?.time || '00:00';
    addToSchedule(`jikan-${anime.mal_id}`, anime.title, `/details/jikan-${anime.mal_id}`, dates[dayNames.indexOf(broadcastDay)] || dates[0], broadcastTime, anime.episodes || 1, 'Japan');
  }
  return Object.values(scheduleMap).slice(0, 80);
}

// EXECUTE ALL FETCHES
const heroData = await fetchHeroData();
const topAiring = await fetchTopAiring();
const newReleases = await fetchNewReleases();
const upcoming = await fetchUpcoming();
const completedFirstPage = await fetchCompletedPage(1);
const trending = await fetchTrending();
const popular = await fetchMostPopular();
const scheduleData = await fetchScheduleData();
const completedData = completedFirstPage;
