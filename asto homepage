<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Muvix‑VQ · Stream Anime, Movies & TV</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    /* =============================================
       COLOR SCHEMA & GLOBAL STYLES
    ============================================= */
    :root {
      --bg-body: #132633;
      --bg-header: #1e2d3a;
      --text-widget-title: #a2c4de;
      --btn-primary: #597691;
      --btn-primary-hover: #455d73;
      --btn-secondary: #5d7080;
      --btn-secondary-hover: #4a5a69;
      --btn-text: #ffffff;
      --popup-bg: #506096;
      --popup-btn: #C0A8FF;
      --popup-btn-text: #1A1A2E;
      --popup-btn-hover: #CFBBFF;
      --show-info-bg: #283654;
      --genre-tag-bg: #bf8fe3;
      --link-accent: #FF7B9C;
      --ep-current: #3B7A99;
      --ep-watched: #476d80;
      --footer-bg: #d4d6d8;
      --dropdown-hover-text: #8ba3f0;
      --font-title: 'Archivo Black', sans-serif;
      --font-body: 'Inter', sans-serif;
      --font-meta: 'Poppins', sans-serif;

      /* Layout constants */
      --sidebar-width: 340px;
      --content-left-pad: 20px;
      --section-gap: 32px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: var(--bg-body);
      font-family: var(--font-body);
      color: #fff;
      line-height: 1.5;
      overflow-x: hidden;
    }
    a { text-decoration: none; color: inherit; }

    /* =============================================
       HEADER
    ============================================= */
    .site-header {
      background: var(--bg-header);
      padding: 12px 24px;
      display: flex; align-items: center; gap: 28px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      position: sticky; top: 0; z-index: 100;
    }
    .logo { font-family: var(--font-title); font-size: 1.5rem; letter-spacing: -1px; }
    .main-nav a {
      font-size: 0.9rem; font-weight: 500; margin-right: 20px; transition: color 0.2s;
    }
    .main-nav a:hover { color: var(--dropdown-hover-text); }

    /* =============================================
       HERO SLIDER — full viewport width
    ============================================= */
    .hero-slider { position: relative; width: 100%; height: 75vh; overflow: hidden; }
    .slides-container { display: flex; transition: transform 0.5s ease-in-out; height: 100%; }
    .slide {
      min-width: 100%; height: 100%; background-size: cover; background-position: center;
      position: relative; display: flex; align-items: flex-end; padding: 0 5%;
    }
    .slide::before {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(to right, rgba(19,38,51,0.95) 30%, rgba(19,38,51,0.3) 100%);
    }
    .slide-content { position: relative; z-index: 2; max-width: 600px; margin-bottom: 10%; }
    .slide-title {
      font-family: var(--font-title); font-size: clamp(28px, 5vw, 36px);
      margin-bottom: 12px; text-shadow: 0 2px 10px rgba(0,0,0,0.6);
    }
    .slide-meta { display: flex; flex-wrap: wrap; gap: 12px; font-size: 0.9rem; margin-bottom: 16px; }
    .meta-item {
      background: rgba(255,255,255,0.1); padding: 4px 10px; border-radius: 4px; font-weight: 500;
    }
    .meta-item.clickable { cursor: pointer; }
    .meta-item.clickable:hover { background: rgba(255,255,255,0.2); }
    .slide-description { font-size: 0.9rem; color: rgba(255,255,255,0.8); margin-bottom: 20px; line-height: 1.6; }
    .slide-actions { display: flex; align-items: center; gap: 16px; }
    .btn-watch {
      background: var(--btn-primary); color: var(--btn-text); padding: 12px 24px;
      border-radius: 50px; font-weight: 700; display: inline-flex; align-items: center; gap: 6px;
      transition: background 0.2s, transform 0.1s;
    }
    .btn-watch:hover { background: var(--btn-primary-hover); transform: scale(1.02); }
    .btn-heart {
      width: 48px; height: 48px; background: rgba(255,255,255,0.1); backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.15); border-radius: 50%;
      display: flex; align-items: center; justify-content: center; cursor: pointer; color: white;
      transition: background 0.2s;
    }
    .btn-heart:hover { background: rgba(255,255,255,0.2); }
    .btn-heart[aria-pressed="true"] { color: var(--link-accent); background: rgba(255,123,156,0.2); }
    .slider-nav {
      position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);
      display: flex; align-items: center; gap: 20px;
      background: rgba(0,0,0,0.5); backdrop-filter: blur(10px); border-radius: 30px; padding: 8px 24px;
    }
    .slider-arrow { background: none; border: none; color: white; font-size: 1.5rem; cursor: pointer; }
    .slide-counter { font-size: 0.9rem; }
    .slider-dots {
      position: absolute; right: 20px; top: 50%; transform: translateY(-50%);
      display: flex; flex-direction: column; gap: 6px;
    }
    .dot { width: 8px; height: 8px; background: rgba(255,255,255,0.3); border-radius: 50%; cursor: pointer; }
    .dot.active { background: white; }

    /* =============================================
       TWO-COLUMN LAYOUT — edge-to-edge like HiAnime
       Max width 1500px, centered.
       Main content: left edge flush (only left gutter = 20px matching header).
       Sidebar: fixed 340px, flush right edge (no outer padding/margin).
    ============================================= */
    .main-layout {
      max-width: 1500px;
      margin: 0 auto;
      padding: 0;                    /* NO outer padding — edge-to-edge */
      display: flex;
      gap: 0;                        /* gap handled internally */
      align-items: flex-start;
    }

    /* LEFT: MAIN CONTENT — flush left, small left gutter only */
    .main-content {
      flex: 1 1 0%;
      min-width: 0;
      padding: 0 24px 0 var(--content-left-pad); /* left gutter 20px, right breathing room 24px */
    }

    /* RIGHT: SIDEBAR — fixed 340px, zero outer spacing, flush right */
    .right-sidebar {
      flex: 0 0 var(--sidebar-width);
      width: var(--sidebar-width);
      min-width: var(--sidebar-width);
      padding: 0;                    /* flush right edge, no outer padding */
    }

    /* =============================================
       SECTION STYLES — titles at left content edge
    ============================================= */
    .section {
      margin: var(--section-gap) 0;
      padding: 0;                    /* no indent — titles start at content left edge */
    }
    .section-header {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 20px;
      padding: 0;                    /* flush with content edge */
    }
    .section-title {
      font-family: var(--font-title); font-size: 1.5rem; color: var(--text-widget-title);
    }
    .section-controls { display: flex; align-items: center; gap: 10px; }
    .view-all {
      font-size: 0.85rem; font-weight: 600; color: var(--link-accent);
      border: 1px solid var(--link-accent); border-radius: 30px; padding: 6px 14px;
      transition: background 0.2s;
    }
    .view-all:hover { background: rgba(255,123,156,0.15); }
    .scroll-arrow {
      width: 36px; height: 36px; border-radius: 50%; background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center;
      cursor: pointer; color: white; font-size: 1.1rem; transition: background 0.2s;
    }
    .scroll-arrow:hover { background: rgba(255,255,255,0.15); }

    /* =============================================
       CARD ROWS & GRIDS
    ============================================= */
    .horizontal-scroll {
      display: flex; gap: 16px; overflow-x: auto; scroll-behavior: smooth; padding-bottom: 10px;
    }
    .horizontal-scroll::-webkit-scrollbar { display: none; }
    .show-card-horiz { flex: 0 0 auto; width: 165px; text-align: center; }
    .card-poster {
      width: 100%; aspect-ratio: 3/4.5; background-size: cover; background-position: center;
      border-radius: 12px; position: relative; margin-bottom: 8px; overflow: hidden;
    }
    .ranking-badge {
      position: absolute; top: 8px; right: 8px; background: rgba(0,0,0,0.6);
      color: white; font-weight: 700; font-size: 0.85rem; padding: 2px 8px; border-radius: 4px;
    }
    .card-title { font-size: 0.85rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    .grid-container {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(155px, 1fr)); gap: 18px;
    }
    @media (min-width: 768px)  { .grid-container { grid-template-columns: repeat(auto-fill, minmax(165px, 1fr)); } }
    @media (min-width: 1024px) { .grid-container { grid-template-columns: repeat(auto-fill, minmax(175px, 1fr)); } }
    .show-card-grid { border-radius: 12px; overflow: hidden; position: relative; }
    .show-card-grid .card-poster { aspect-ratio: 3/4.5; width: 100%; background-size: cover; }
    .poster-badge {
      position: absolute; top: 8px; left: 8px; background: rgba(0,0,0,0.7);
      color: white; padding: 2px 6px; border-radius: 4px; font-size: 0.7rem;
    }
    .poster-badge.right { left: auto; right: 8px; }
    .card-meta-grid { padding: 6px 8px; font-size: 0.75rem; color: rgba(255,255,255,0.7); }
    .card-title-grid {
      font-weight: 600; font-size: 0.85rem; margin-top: 2px; padding: 0 8px 8px;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }

    /* Toggle tabs */
    .toggle-tabs { display: flex; gap: 6px; }
    .toggle-tab {
      padding: 6px 14px; border-radius: 30px; background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1); font-size: 0.8rem; cursor: pointer; transition: all 0.2s;
      color: #fff; font-family: var(--font-body);
    }
    .toggle-tab.active {
      background: var(--popup-btn); color: var(--popup-btn-text);
      border-color: var(--popup-btn); font-weight: 600;
    }

    /* =============================================
       SIDEBAR WIDGETS
       Flush right — no border-radius on right edge,
       no margin-right, no padding-right gaps.
       Stack seamlessly top to bottom.
    ============================================= */
    .right-sidebar {
      border-left: 1px solid rgba(255,255,255,0.07);
    }

    .sidebar-widget {
      background: var(--show-info-bg);
      padding: 18px 16px 18px 18px;
      border-bottom: 1px solid rgba(255,255,255,0.07);
      /* No border-radius — flush against edge like HiAnime sidebar */
      border-radius: 0;
      /* No margin — widgets stack flush with zero gap */
      margin: 0;
    }
    .sidebar-widget .section-title {
      font-size: 1.1rem;
      margin-bottom: 14px;
      padding: 0;
    }

    /* Sidebar list items */
    .sidebar-list { list-style: none; }
    .sidebar-list-item {
      display: flex; gap: 12px; align-items: center;
      margin-bottom: 14px; cursor: pointer;
    }
    .sidebar-list-item:last-child { margin-bottom: 0; }
    .sidebar-rank {
      font-size: 1.6rem; font-weight: 700; color: rgba(255,255,255,0.15);
      width: 30px; flex-shrink: 0; text-align: center;
    }
    .sidebar-thumb {
      width: 54px; height: 76px; object-fit: cover;
      border-radius: 6px; flex-shrink: 0;
      background: rgba(255,255,255,0.05);
    }
    .sidebar-info { min-width: 0; }
    .sidebar-info h4 {
      font-weight: 600; font-size: 0.82rem;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      margin-bottom: 3px;
    }
    .sidebar-info p { font-size: 0.68rem; color: rgba(255,255,255,0.6); margin-bottom: 2px; }
    .sidebar-info .views { font-size: 0.68rem; color: var(--link-accent); }

    /* Trending period tabs in sidebar header */
    .sidebar-header {
      display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px;
    }

    /* =============================================
       EPISODE SCHEDULE WIDGET (inside sidebar)
    ============================================= */
    .esw-head {
      display: flex; justify-content: space-between; align-items: center;
      gap: 8px; flex-wrap: wrap; margin-bottom: 12px;
    }
    .esw-title {
      font-size: 13px; font-weight: 700; color: var(--text-widget-title);
      letter-spacing: 0.5px; text-transform: uppercase;
      display: flex; align-items: center; gap: 8px;
    }
    .esw-clock {
      display: flex; align-items: center; gap: 7px;
      background: var(--bg-header); border: 1px solid var(--btn-primary);
      border-radius: 999px; padding: 5px 12px; flex-shrink: 0;
    }
    .esw-clock-world { width: 14px; height: 14px; flex-shrink: 0; }
    .esw-clock-inner { display: flex; align-items: center; gap: 6px; }
    .esw-clock-date { font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.6); }
    .esw-clock-sep { font-size: 10px; color: rgba(255,255,255,0.3); }
    .esw-clock-time { font-size: 11px; font-weight: 700; color: var(--text-widget-title); }
    .esw-days {
      display: flex; align-items: center; padding: 8px 0;
      border-bottom: 1px solid rgba(255,255,255,0.06); margin-bottom: 8px; gap: 0;
    }
    .esw-nav {
      background: none; border: none; color: rgba(255,255,255,0.4); cursor: pointer;
      width: 24px; height: 24px; display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; border-radius: 4px; transition: color 0.2s, background 0.2s;
    }
    .esw-nav:hover { color: var(--popup-btn); background: var(--bg-header); }
    .esw-days-scroll {
      display: flex; gap: 4px; flex: 1; overflow: hidden; justify-content: space-between;
    }
    .esw-day-card {
      flex: 1; min-width: 0; background: var(--bg-header);
      border: 1px solid rgba(255,255,255,0.06); border-radius: 8px;
      padding: 6px 2px; text-align: center; cursor: pointer;
      transition: all 0.18s; user-select: none;
    }
    .esw-day-card:hover { border-color: var(--popup-btn); background: var(--show-info-bg); }
    .esw-day-card.esw-active { background: var(--btn-primary); border-color: var(--popup-btn); }
    .esw-day-card.esw-today { border-color: var(--link-accent) !important; }
    .esw-day-card.esw-today .esw-dc-day { color: var(--link-accent); }
    .esw-dc-day { font-size: 8px; font-weight: 700; color: rgba(255,255,255,0.4); text-transform: uppercase; }
    .esw-dc-date { font-size: 15px; font-weight: 800; color: #fff; line-height: 1.1; margin: 1px 0; }
    .esw-dc-month { font-size: 8px; color: rgba(255,255,255,0.5); }
    .esw-day-card.esw-active .esw-dc-day,
    .esw-day-card.esw-active .esw-dc-date,
    .esw-day-card.esw-active .esw-dc-month { color: #fff; }
    .esw-day-card.esw-today.esw-active .esw-dc-day { color: var(--link-accent); }
    .esw-body { padding: 4px 0; }
    .esw-status-bar {
      font-size: 11px; color: rgba(255,255,255,0.4); padding: 4px 0 8px;
      display: flex; align-items: center; gap: 5px;
    }
    .esw-rows { display: flex; flex-direction: column; gap: 5px; }
    .esw-row {
      display: flex; align-items: center; gap: 8px;
      background: var(--bg-header); border: 1px solid rgba(255,255,255,0.06);
      border-radius: 8px; padding: 8px 10px; cursor: pointer;
      transition: all 0.18s; text-decoration: none; color: inherit;
    }
    .esw-row:hover { border-color: var(--popup-btn); background: var(--show-info-bg); }
    .esw-row-time {
      font-size: 11px; font-weight: 700; color: var(--text-widget-title);
      min-width: 38px; flex-shrink: 0;
    }
    .esw-row-title {
      flex: 1; font-size: 12px; font-weight: 500; color: #fff;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0;
    }
    .esw-row-ep {
      font-size: 10px; color: rgba(255,255,255,0.6);
      background: var(--show-info-bg); border: 1px solid var(--btn-primary);
      border-radius: 4px; padding: 1px 6px; white-space: nowrap; flex-shrink: 0;
    }
    .esw-row-btn {
      width: 26px; height: 26px; border-radius: 50%;
      background: var(--btn-primary); border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; transition: background 0.2s;
    }
    .esw-row-btn:hover { background: var(--btn-primary-hover); }
    .esw-row-btn svg { width: 11px; height: 11px; }
    .esw-aired { opacity: 0.45; }
    .esw-aired .esw-row-time { color: rgba(255,255,255,0.4); }
    .esw-more-wrap { margin-top: 8px; display: flex; justify-content: flex-end; }
    .esw-more-btn {
      background: none; border: 1px solid var(--btn-primary);
      color: var(--popup-btn); border-radius: 6px; padding: 4px 12px;
      font-size: 11px; cursor: pointer; transition: all 0.2s; font-family: inherit;
    }
    .esw-more-btn:hover { background: var(--btn-primary); color: #fff; }
    .esw-empty { text-align: center; padding: 20px 12px; color: rgba(255,255,255,0.4); font-size: 12px; }

    /* =============================================
       FOOTER
    ============================================= */
    .site-footer {
      background: var(--footer-bg); color: #1a1a2e;
      padding: 30px 20px; text-align: center; margin-top: 60px;
    }

    /* =============================================
       RESPONSIVE
    ============================================= */
    @media (max-width: 1100px) {
      :root { --sidebar-width: 300px; }
    }

    @media (max-width: 900px) {
      /* Stack sidebar below main on tablet/mobile */
      .main-layout {
        flex-direction: column;
      }
      .main-content {
        padding: 0 16px;     /* equal padding both sides on mobile */
        width: 100%;
      }
      .right-sidebar {
        width: 100%;
        min-width: auto;
        flex: 1 1 auto;
        border-left: none;
        border-top: 1px solid rgba(255,255,255,0.07);
      }
      .sidebar-widget {
        border-radius: 0;
      }
    }

    @media (max-width: 768px) {
      .hero-slider { height: 55vh; }
      .slider-nav .slider-arrow { display: none; }
      .horizontal-scroll { gap: 12px; }
      .show-card-horiz { width: 135px; }
      .esw-clock { padding: 4px 10px; gap: 4px; }
      .esw-clock-date { font-size: 9px; }
      .esw-clock-time { font-size: 10px; }
      .esw-dc-date { font-size: 13px; }
      .esw-row-title { font-size: 11px; }
    }

    @media (max-width: 480px) {
      .main-content { padding: 0 10px; }
    }

    @media (max-width: 360px) {
      .esw-clock-date, .esw-clock-sep { display: none; }
    }
  </style>
</head>
<body>

