  <!-- ===== SCRIPTS ===== -->
  <script>
    // ---------- HERO SLIDER ----------
    const slidesContainer = document.getElementById('slidesContainer');
    const prevBtn = document.getElementById('prevSlide');
    const nextBtn = document.getElementById('nextSlide');
    const counter = document.getElementById('slideCounter');
    const dots = document.querySelectorAll('#sliderDots .dot');
    let currentSlide = 0;
    const totalSlides = {heroData.length};

    function goToSlide(index) {
      currentSlide = (index + totalSlides) % totalSlides;
      slidesContainer.style.transform = `translateX(-${currentSlide * 100}%)`;
      counter.textContent = `${currentSlide + 1} / ${totalSlides}`;
      dots.forEach(d => d.classList.remove('active'));
      if (dots[currentSlide]) dots[currentSlide].classList.add('active');
    }
    prevBtn.addEventListener('click', () => goToSlide(currentSlide - 1));
    nextBtn.addEventListener('click', () => goToSlide(currentSlide + 1));
    dots.forEach(dot => dot.addEventListener('click', () => goToSlide(parseInt(dot.dataset.index))));
    setInterval(() => goToSlide(currentSlide + 1), 6000);
    goToSlide(0);

    // ---------- HORIZONTAL SCROLL ARROWS ----------
    function setupScroll(containerId, leftBtnId, rightBtnId) {
      const container = document.getElementById(containerId);
      const left = document.getElementById(leftBtnId);
      const right = document.getElementById(rightBtnId);
      if (!container || !left || !right) return;
      left.addEventListener('click', () => container.scrollBy({ left: -350, behavior: 'smooth' }));
      right.addEventListener('click', () => container.scrollBy({ left: 350, behavior: 'smooth' }));
    }
    setupScroll('topAiringScroll', 'topAiringLeft', 'topAiringRight');
    setupScroll('upcomingScroll', 'upcomingLeft', 'upcomingRight');

    // ---------- NEW RELEASES TOGGLE ----------
    const releaseTabs = document.querySelectorAll('#releaseTabs .toggle-tab');
    const grid = document.getElementById('newReleasesGrid');
    const titleElem = document.getElementById('newReleasesTitle');
    releaseTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        releaseTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const filter = tab.dataset.filter;
        grid.querySelectorAll('.show-card-grid').forEach(card => {
          card.style.display = (filter === 'all' || card.dataset.type === filter) ? '' : 'none';
        });
        titleElem.textContent = filter === 'all' ? 'New Releases' : `Latest ${tab.textContent}`;
      });
    });

    // ---------- HEART TOGGLE ----------
    document.querySelectorAll('.btn-heart').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const pressed = btn.getAttribute('aria-pressed') === 'true';
        btn.setAttribute('aria-pressed', String(!pressed));
      });
    });

    // ---------- TOUCH SWIPE ON HERO ----------
    let touchStartX = 0;
    slidesContainer.addEventListener('touchstart', e => { touchStartX = e.changedTouches[0].screenX; });
    slidesContainer.addEventListener('touchend', e => {
      const diff = touchStartX - e.changedTouches[0].screenX;
      if (Math.abs(diff) > 50) goToSlide(diff > 0 ? currentSlide + 1 : currentSlide - 1);
    });

    // ---------- EPISODE SCHEDULE WIDGET ----------
    (function(){
      const scheduleRaw = {JSON.stringify(scheduleData)};
      const DAY_S = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
      const MON_S = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      const DAY_F = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
      let weekOffset = 0, selDay = 0, showCount = 6, weekDays = [];

      function pad(n){ return String(n).padStart(2,'0'); }
      function sameDay(a, b){ return a.getFullYear()===b.getFullYear() && a.getMonth()===b.getMonth() && a.getDate()===b.getDate(); }
      function isToday(d){ return sameDay(d, new Date()); }

      function buildWeek(){
        const now = new Date();
        const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
        const sun = new Date(today);
        sun.setDate(today.getDate() - today.getDay() + weekOffset * 7);
        const days = [];
        for(let i=0; i<7; i++){
          const d = new Date(sun);
          d.setDate(sun.getDate() + i);
          days.push(d);
        }
        return days;
      }

      function autoSelectToday(){
        weekDays = buildWeek();
        let found = -1;
        for(let i=0; i<weekDays.length; i++){ if(isToday(weekDays[i])){ found = i; break; } }
        selDay = found >= 0 ? found : 0;
      }

      function getEpisodesForDay(dayDate){
        const result = [];
        const now = new Date();
        const seen = {};
        for(const ep of scheduleRaw){
          const airDate = new Date(ep.airDate + 'T' + (ep.airTime || '00:00'));
          const localAir = new Date(airDate);
          if(sameDay(localAir, dayDate)){
            const key = ep.title;
            if(!seen[key]){
              seen[key] = true;
              result.push({
                time: ep.airTime || '00:00',
                title: ep.title,
                url: ep.url,
                epNum: ep.episodeNumber || 1,
                aired: localAir < now
              });
            }
          }
        }
        result.sort((a,b) => a.time.localeCompare(b.time));
        return result;
      }

      function renderDays(){
        weekDays = buildWeek();
        const scroll = document.getElementById('esw-days-scroll');
        if(!scroll) return;
        let html = '';
        for(let i=0; i<7; i++){
          const d = weekDays[i];
          let cls = 'esw-day-card';
          if(isToday(d)) cls += ' esw-today';
          if(i === selDay) cls += ' esw-active';
          html += `<div class="${cls}" data-esw-i="${i}">
            <div class="esw-dc-day">${DAY_S[d.getDay()]}</div>
            <div class="esw-dc-date">${d.getDate()}</div>
            <div class="esw-dc-month">${MON_S[d.getMonth()]}</div>
          </div>`;
        }
        scroll.innerHTML = html;
        scroll.querySelectorAll('.esw-day-card').forEach(card => {
          card.addEventListener('click', function(){
            selDay = parseInt(this.getAttribute('data-esw-i'));
            showCount = 6;
            renderDays();
            renderRows();
          });
        });
      }

      function renderRows(){
        const dayDate = weekDays[selDay];
        if(!dayDate) return;
        const episodes = getEpisodesForDay(dayDate);
        const rowsEl = document.getElementById('esw-rows');
        const statusEl = document.getElementById('esw-status');
        const moreWrap = document.getElementById('esw-more-wrap');
        const moreBtn = document.getElementById('esw-more-btn');
        if(!rowsEl) return;
        const dLabel = isToday(dayDate) ? 'Today' : DAY_F[dayDate.getDay()];
        statusEl.innerHTML = `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg> ${dLabel}, ${MON_S[dayDate.getMonth()]} ${dayDate.getDate()} — ${episodes.length} episode${episodes.length!==1?'s':''}`;
        if(episodes.length === 0){
          rowsEl.innerHTML = '<div class="esw-empty">No episodes scheduled</div>';
          moreWrap.style.display = 'none';
          return;
        }
        const visible = episodes.slice(0, showCount);
        rowsEl.innerHTML = visible.map(ep => `
          <a class="esw-row${ep.aired?' esw-aired':''}" href="${ep.url}">
            <span class="esw-row-time">${ep.time.slice(0,5)}</span>
            <span class="esw-row-title">${ep.title}</span>
            <span class="esw-row-ep">EP ${pad(ep.epNum)}</span>
            <span class="esw-row-btn" onclick="event.preventDefault();event.stopPropagation();window.location.href='${ep.url}'">
              <svg viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </span>
          </a>
        `).join('');
        if(episodes.length > showCount){
          moreWrap.style.display = 'flex';
          moreBtn.textContent = `Show more (${episodes.length - showCount} more)`;
        } else {
          moreWrap.style.display = 'none';
        }
      }

      function startClock(){
        function tick(){
          const n = new Date();
          const h = n.getHours(), mi = n.getMinutes();
          const ampm = h >= 12 ? 'PM' : 'AM';
          const h12 = h % 12 || 12;
          const timeEl = document.getElementById('esw-time');
          const dateEl = document.getElementById('esw-date');
          if(timeEl) timeEl.textContent = pad(h12)+':'+pad(mi)+' '+ampm;
          if(dateEl) dateEl.textContent = pad(n.getDate())+'/'+pad(n.getMonth()+1)+'/'+n.getFullYear();
        }
        tick();
        setInterval(tick, 30000);
      }

      autoSelectToday();
      renderDays();
      renderRows();
      startClock();

      document.getElementById('esw-prev').addEventListener('click', ()=>{
        weekOffset--;
        autoSelectToday();
        renderDays();
        renderRows();
      });
      document.getElementById('esw-next').addEventListener('click', ()=>{
        weekOffset++;
        selDay = 0;
        renderDays();
        renderRows();
      });
      document.getElementById('esw-more-btn').addEventListener('click', ()=>{
        showCount += 6;
        renderRows();
      });
    })();
  </script>
</body>
</html>
